{
  "name": "how-much",
  "version": "0.1.0",
  "description": "Local proxy that tracks LLM API costs in real time",
  "license": "MIT",
  "type": "module",
  "bin": {
    "how-much": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atenareply/tokenpricing": "^0.1.1",
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true
  }
}
